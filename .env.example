# Copy to .env on the server. Never commit the real .env.
PORT=3000

# MySQL (from Hostinger hPanel → Databases → MySQL Databases)
DB_HOST=localhost
DB_PORT=3306
DB_USER=u123456789_vmy
DB_PASSWORD=change-me
DB_NAME=u123456789_vmy

# JWT secret — generate a long random string (e.g. `openssl rand -hex 48`)
JWT_SECRET=replace-with-a-long-random-string

# Where uploaded files are stored on disk (absolute path recommended on Hostinger)
UPLOAD_DIR=/home/u123456789/vmoveyou-uploads

# Limits
MAX_UPLOAD_MB=100
TRANSFER_EXPIRY_DAYS=7

# CORS — your frontend origin(s), comma-separated
CORS_ORIGIN=https://your-frontend-vmoveyou.com,https://primlink-flash-transfer.pages.dev
# Public base URL of this backend (used to build download URLs)
PUBLIC_BASE_URL=https://backend.your-vmoveyou.com
